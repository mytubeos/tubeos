# ==================== SERVER ====================
PORT=8080
NODE_ENV=development

# ==================== DATABASE ====================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tubeos

# ==================== JWT ====================
JWT_ACCESS_SECRET=your_super_secret_access_key_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ==================== REDIS ====================
# Local: redis://localhost:6379
# Upstash: rediss://default:password@host.upstash.io:6380
REDIS_URL=redis://localhost:6379

# ==================== CORS ====================
CLIENT_URL=http://localhost:3000
# Optional — comma-separated extra allowed origins (staging frontend, alternate
# local dev port, etc). If unset: defaults to the Vite/CRA dev ports in
# development (http://localhost:3000,http://localhost:5173), and to nothing
# extra in production. Set to an empty string to disable the dev defaults.
# CORS_EXTRA_ORIGINS=http://localhost:3000,http://localhost:5173
# Vercel sets VERCEL_URL automatically on their platform — no action needed.
# Set FRONTEND_URL only if you deploy the frontend somewhere Vercel-detection
# and CLIENT_URL/CORS_EXTRA_ORIGINS don't already cover.
# FRONTEND_URL=https://your-frontend-domain.com

# ==================== YOUTUBE OAUTH ====================
YOUTUBE_CLIENT_ID=your_google_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_google_oauth_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:8080/api/v1/youtube/callback

# YouTube Data API v3 key (no OAuth) — required for the Trend Opportunity
# Scanner (growth.service.js: mostPopular chart lookup). Without this,
# Trends always falls back to a static curated list.
# Get one at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_data_api_key

# ==================== GOOGLE CLOUD STORAGE (video staging) ====================
# Videos are streamed to GCS instead of being buffered in RAM, then streamed
# from GCS to YouTube. If GCS_BUCKET is unset, uploads fall back to in-memory
# storage (fine for local dev, NOT for production — large files can OOM).
GCS_BUCKET=your-gcs-bucket-name
GCS_PROJECT_ID=your-gcp-project-id
# On Cloud Run/GCE, Application Default Credentials are used automatically.
# Locally, point this at a service-account key JSON file:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ==================== EMAIL (Brevo) ====================
# Optional — if not set, emails are skipped and users auto-verified
BREVO_API_KEY=your_brevo_api_key
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# ==================== AI APIs ====================
# Optional — required for AI features
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
# Groq — free tier, used for Agency bulk replies (llama-3.3-70b-versatile)
# Get free key at: https://console.groq.com
GROQ_API_KEY=gsk_...
# AI_TEST_MODE=true → sab plans Gemini use karenge (testing ke liye, free)
# AI_TEST_MODE=false → production model routing (Sonnet/Opus/Groq)
AI_TEST_MODE=false

# ==================== SENTRY (error monitoring) ====================
# Optional — if unset, error tracking is disabled and the app runs normally.
# Get a DSN at https://sentry.io (Node/Express project).
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ==================== RAZORPAY ====================
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Webhook secret — set in Razorpay Dashboard > Webhooks
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ==================== RATE LIMITS (Optional) ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
