# ================================
# TubeOS — Environment Variables
# ================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# --- SERVER ---
PORT=5000
NODE_ENV=development

# --- MONGODB ---
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/tubeos?retryWrites=true&w=majority

# --- JWT SECRETS ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_super_secret_access_token_key_here_min_64_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_here_min_64_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- REDIS (Upstash) ---
REDIS_URL=rediss://:<password>@<host>.upstash.io:6379

# --- CORS ---
CLIENT_URL=http://localhost:3000

# --- EMAIL (For password reset) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=TubeOS <noreply@tubeos.app>

# --- AI APIS (Add later in Part 5) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- YOUTUBE (Add in Part 2) ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:5000/api/v1/youtube/callback

# --- RAZORPAY (Add later) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- RATE LIMITING ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

